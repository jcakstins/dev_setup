# =============================================================================
#  ~/.secrets — API keys and personal tokens
#
#  SETUP: Copy this file to ~/.secrets and fill in your values.
#    cp ~/github/dev_setup/.secrets.example ~/.secrets
#    chmod 600 ~/.secrets
#
#  This file is sourced by ~/.zshrc at the end of shell startup.
#  NEVER commit ~/.secrets — it is in .gitignore_global.
# =============================================================================

# ── OpenAI ────────────────────────────────────────────────────────────────────
export OPENAI_API_KEY=""

# ── Anthropic ─────────────────────────────────────────────────────────────────
export ANTHROPIC_API_KEY=""

# ── GitHub ────────────────────────────────────────────────────────────────────
# export GITHUB_TOKEN=""

# ── AWS ───────────────────────────────────────────────────────────────────────
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""
# export AWS_DEFAULT_REGION="eu-west-2"

# ── Other ─────────────────────────────────────────────────────────────────────
# Add project-specific tokens here
