# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.cursor/
*.suo
*.user
*.swp
*.swo
*~
\#*\#
.\#*
.idea/
*.iml

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
ENV/
env/
.env
.env.*
!.env.example
!.env.sample
pip-log.txt
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/

